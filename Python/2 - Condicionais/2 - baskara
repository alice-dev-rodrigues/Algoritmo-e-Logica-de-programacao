a = float(input('Coeficiente a: '))
b = float(input('Coeficiente b: '))
c = float(input('Coeficiente c: '))
delta = b ** 2 - 4 * a * c
x1 = (- b + (delta ** 0.5)) / (2 * a)
x2 = (- b - (delta ** 0.5)) / (2 * a)
if delta < 0:
    print('Esta equacao nao possui raizes reais.')
else:
    print(f'X1 = {x1:.4f}')
    print(f'X2 = {x2:.4f}')
